# V6 .env.example.staging — staging environment (pre-production validation)
# This file documents the SHAPE of staging env vars. Values are placeholders;
# actual secrets come from the secrets manager (Epic 7 Task 7.2).
NODE_ENV=staging
GATEWAY_PORT=8080
HOST=0.0.0.0
DATABASE_URL=postgres://REPLACE_WITH_SECRETS_MANAGER/treasury_staging
DATABASE_ADMIN_URL=postgres://REPLACE_WITH_SECRETS_MANAGER/postgres
SERVICE_DB_PASSWORD=REPLACE_WITH_SECRETS_MANAGER
DB_POOL_MAX=10
CORS_ORIGIN=https://staging.treasury.example.com
AUTH_REQUIRED=true
INTERNAL_AUTH_REQUIRED=true
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_SECRETS_MANAGER
SESSION_COOKIE_SECURE=true
WEBHOOK_SECRET=REPLACE_WITH_SECRETS_MANAGER
DEMO_WEBHOOK_SECRET=REPLACE_WITH_SECRETS_MANAGER
SERVICE_TIMEOUT_MS=5000
SERVICE_RETRIES=3
RELAY_POLL_INTERVAL_MS=500
JOB_POLL_INTERVAL_MS=500
SIMULATED_STATEMENT_EMIT=true
ALLOW_DEMO_RESET=true
DEMO_SEED_ENABLED=true
