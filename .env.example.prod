# V6 .env.example.prod — production environment SHAPE (validated by the prod-config gate)
# This file is a shape document. No real secrets here — they come from the secrets manager.
# Every required variable for PRODUCTION_MODE=true must be present.
NODE_ENV=production
PRODUCTION_MODE=true
GATEWAY_PORT=8080
HOST=0.0.0.0
DATABASE_URL=postgres://REPLACE_WITH_SECRETS_MANAGER/treasury_prod
DATABASE_ADMIN_URL=postgres://REPLACE_WITH_SECRETS_MANAGER/postgres
SERVICE_DB_PASSWORD=REPLACE_WITH_SECRETS_MANAGER
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT_MS=10000
DB_IDLE_TX_TIMEOUT_MS=10000
HTTP_BODY_LIMIT_BYTES=1048576
CORS_ORIGIN=https://treasury.example.com
AUTH_REQUIRED=true
INTERNAL_AUTH_REQUIRED=true
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_SECRETS_MANAGER
SESSION_COOKIE_SECURE=true
SESSION_ABSOLUTE_TTL_HOURS=8
SESSION_IDLE_TTL_MINUTES=30
WEBHOOK_SECRET=REPLACE_WITH_SECRETS_MANAGER
DEMO_WEBHOOK_SECRET=REPLACE_WITH_SECRETS_MANAGER
TRUST_PROXY_HEADERS=true
WALLET_SERVICE_URL=http://wallet-service:4101
POLICY_SERVICE_URL=http://policy-service:4102
COMPLIANCE_SERVICE_URL=http://compliance-service:4103
PAYMENT_SERVICE_URL=http://payment-service:4104
ACCOUNTING_SERVICE_URL=http://accounting-service:4105
RECONCILIATION_SERVICE_URL=http://reconciliation-service:4106
OPERATIONS_SERVICE_URL=http://operations-service:4107
SERVICE_TIMEOUT_MS=5000
SERVICE_RETRIES=3
PAYMENT_MUTATION_TIMEOUT_MS=15000
RELAY_POLL_INTERVAL_MS=500
JOB_POLL_INTERVAL_MS=500
RELAY_DELIVERY_TIMEOUT_MS=10000
BREAKER_MAX_FAILURES=5
BREAKER_RESET_MS=30000
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX=200
STATE_RATE_LIMIT_MAX=50
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_LOCKOUT_MS=300000
WATCHDOG_INTERVAL_MS=60000
WATCHDOG_STUCK_EXECUTING_MS=300000
WATCHDOG_OUTBOX_LAG_MS=60000
WATCHDOG_PENDING_JOB_AGE_MS=300000
ALLOW_DEMO_RESET=false
DEMO_SEED_ENABLED=false
