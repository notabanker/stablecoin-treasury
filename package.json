{
  "name": "corporate-stablecoin-treasury-platform",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start:gateway": "node services/api-gateway/src/index.mjs",
    "start:wallet": "node services/wallet-service/src/index.mjs",
    "start:policy": "node services/policy-service/src/index.mjs",
    "start:compliance": "node services/compliance-service/src/index.mjs",
    "start:payment": "node services/payment-service/src/index.mjs",
    "start:accounting": "node services/accounting-service/src/index.mjs",
    "start:reconciliation": "node services/reconciliation-service/src/index.mjs",
    "start:operations": "node services/operations-service/src/index.mjs",
    "check": "node scripts/check-syntax.mjs",
    "smoke": "node scripts/smoke.mjs",
    "test": "node --test tests/unit/*.test.mjs",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:concurrency": "node --test tests/concurrency/*.test.mjs",
    "test:all": "npm run test && npm run test:integration && npm run test:concurrency",
    "migrate": "node db/scripts/migrate.mjs",
    "db:setup": "node db/scripts/setup.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
