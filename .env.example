# Server
GATEWAY_PORT=8080
HOST=127.0.0.1

# Database
DATABASE_URL=postgres://127.0.0.1:5432/treasury_dev
DATABASE_ADMIN_URL=postgres://127.0.0.1:5432/postgres
SERVICE_DB_PASSWORD=service-dev-password
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT_MS=5000
DB_IDLE_TX_TIMEOUT_MS=5000

# HTTP
HTTP_BODY_LIMIT_BYTES=1048576
CORS_ORIGIN=

# Services
SERVICE_TIMEOUT_MS=2500
PAYMENT_MUTATION_TIMEOUT_MS=10000
SERVICE_RETRIES=2
WALLET_SERVICE_URL=http://127.0.0.1:4101
POLICY_SERVICE_URL=http://127.0.0.1:4102
COMPLIANCE_SERVICE_URL=http://127.0.0.1:4103
PAYMENT_SERVICE_URL=http://127.0.0.1:4104
ACCOUNTING_SERVICE_URL=http://127.0.0.1:4105
RECONCILIATION_SERVICE_URL=http://127.0.0.1:4106
OPERATIONS_SERVICE_URL=http://127.0.0.1:4107

# Auth (defaults to off for local dev)
# AUTH_REQUIRED=true
# INTERNAL_AUTH_REQUIRED=true
# INTERNAL_SERVICE_TOKEN=changeme-prod-token
# SESSION_COOKIE_SECURE=true

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=1000
# RATE_LIMIT_MAX=200
# STATE_RATE_LIMIT_MAX=50
# LOGIN_RATE_LIMIT_WINDOW_MS=60000
# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_LOCKOUT_MS=300000

# Webhooks (must not be "sandbox-webhook-secret" in production)
# WEBHOOK_SECRET=
# DEMO_WEBHOOK_SECRET=

# Workers
# RELAY_POLL_INTERVAL_MS=500
# JOB_POLL_INTERVAL_MS=500

# Production
# PRODUCTION_MODE=true
# NODE_ENV=production
# DEMO_SEED_ENABLED=false
